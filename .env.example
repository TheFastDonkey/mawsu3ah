DJANGO_SECRET_KEY=change-me-in-production-must-be-at-least-50-characters-long
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,al-kubra.com,www.al-kubra.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://al-kubra.com,https://www.al-kubra.com
DJANGO_ADMIN_URL=manage
DJANGO_SECURE_SSL_REDIRECT=true
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=false
SECURE_HSTS_PRELOAD=false

# Reverse proxy trust. Only enable these when a trusted proxy/load-balancer sets these headers.
TRUST_X_FORWARDED_PROTO=false
ADMIN_TRUST_X_FORWARDED_FOR=false

ADMIN_ALLOWED_IPS=
# Example: REDIS_URL=redis://localhost:6379/0
REDIS_URL=
# Optional: write logs to a rotating file instead of stdout.
LOG_FILE=
DB_NAME=mawsu3ah
DB_USER=mawsu3ah
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432
# Email (SMTP)
# Supported: Gmail (requires App Password), Outlook, Zoho, SendGrid, Mailgun, AWS SES, etc.
# Use console backend for local dev (prints emails to terminal), or smtp backend for real sending.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=noreply@example.com
EMAIL_HOST_PASSWORD=change-me
DEFAULT_FROM_EMAIL=noreply@example.com
CONTACT_EMAIL=admin@example.com
